# Reeboot the Earth — environment template
# Copy to .env and fill in real values. .env is gitignored; this template is safe to commit.

# ── NASA ──────────────────────────────────────────────────────────────────────
NASA_FIRMS_API_KEY=your_nasa_firms_key_here
NASA_EARTHDATA_USERNAME=your_username_here
NASA_EARTHDATA_PASSWORD=your_password_here

# ── LLM ───────────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here

# ── Crop Data ─────────────────────────────────────────────────────────────────
USDA_NASS_API_KEY=your_usda_nass_key_here
OPENET_API_KEY=your_openet_key_here

# ── Policy / Web search ───────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here

# ── SDG&E / Fire Partners (placeholder — approval required) ───────────────────
SDGE_FPI_API_KEY=your_sdge_fpi_key_here
PYRECAST_API_KEY=your_pyrecast_key_here
WIFIRE_API_KEY=your_wifire_key_here

# ── n8n webhook (for action briefing email button) ───────────────────────────
# The "Trigger n8n webhook" button on the Plan page POSTs the briefing PDF
# (base64) and recipient metadata to this URL. Your n8n workflow handles
# the actual email delivery via its Gmail/SMTP/SendGrid node. Override here
# to point at your own webhook; defaults to the one hardcoded in main.py.
N8N_WEBHOOK_URL=https://your-instance.app.n8n.cloud/webhook/your-id
