# ── Required ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ── Crop Prices & Yields (free, instant key) ──────────────────────────────────
# Sign up: https://quickstats.nass.usda.gov/api
USDA_NASS_API_KEY=your_usda_nass_api_key_here

# ── Soil Moisture (free, NASA account) ────────────────────────────────────────
# Sign up: https://urs.earthdata.nasa.gov/users/new
NASA_EARTHDATA_USERNAME=your_earthdata_username_here
NASA_EARTHDATA_PASSWORD=your_earthdata_password_here

# ── Water Use per Field (free, request form) ──────────────────────────────────
# Request access: https://openetdata.org/access
OPENET_API_KEY=your_openet_api_key_here
